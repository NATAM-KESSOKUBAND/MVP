# .env.example
# 이 파일을 .env로 복사 후 실제 값 입력
# cp .env.example .env

# ─────────────────────────────────────────────
# 음악 인식 API
# ─────────────────────────────────────────────
# ACRCloud (https://www.acrcloud.com) - 주력
ACRCLOUD_HOST=identify-ap-southeast-1.acrcloud.com
ACRCLOUD_ACCESS_KEY=your_access_key
ACRCLOUD_ACCESS_SECRET=your_access_secret

# AudD (https://audd.io) - 백업
AUDD_API_TOKEN=your_audd_token

# ─────────────────────────────────────────────
# Google Cloud Vision (로고/이미지 분석)
# ─────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
GOOGLE_API_KEY=your_google_api_key

# ─────────────────────────────────────────────
# YouTube Data API v3
# ─────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2

# S3 버킷
S3_BUCKET=your-video-input-bucket
S3_RESULTS_BUCKET=your-results-bucket

# ECS
ECS_CLUSTER=copyright-detector-cluster
ECS_TASK_DEFINITION=copyright-detector-task
ECS_SUBNETS=subnet-xxx,subnet-yyy
ECS_SECURITY_GROUPS=sg-xxx

# AWS Rekognition 사용 여부
USE_REKOGNITION=true

# ─────────────────────────────────────────────
# 데이터베이스
# ─────────────────────────────────────────────
# 로컬 개발: SQLite (자동 생성)
DATABASE_URL=sqlite:///./copyright_db.sqlite

# 프로덕션: PostgreSQL on RDS
# DATABASE_URL=postgresql://user:password@rds-host:5432/copyright_detector

# ─────────────────────────────────────────────
# Redis (캐시) - 선택적
# ─────────────────────────────────────────────
# REDIS_HOST=your-elasticache-endpoint
# REDIS_PORT=6379

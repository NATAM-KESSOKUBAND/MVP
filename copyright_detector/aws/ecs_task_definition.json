# aws/ecs_task_definition.json
# ECS Fargate 태스크 정의
# 배포: aws ecs register-task-definition --cli-input-json file://ecs_task_definition.json

{
  "family": "copyright-detector-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "4096",
  "memory": "8192",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/copyrightDetectorTaskRole",

  "containerDefinitions": [
    {
      "name": "copyright-detector",
      "image": "ACCOUNT_ID.dkr.ecr.ap-northeast-2.amazonaws.com/copyright-detector:latest",
      "essential": true,

      "command": ["python", "main.py"],

      "environment": [
        {"name": "AWS_REGION", "value": "ap-northeast-2"},
        {"name": "USE_REKOGNITION", "value": "true"}
      ],

      "secrets": [
        {"name": "ACRCLOUD_HOST",          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/ACRCLOUD_HOST"},
        {"name": "ACRCLOUD_ACCESS_KEY",    "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/ACRCLOUD_ACCESS_KEY"},
        {"name": "ACRCLOUD_ACCESS_SECRET", "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/ACRCLOUD_ACCESS_SECRET"},
        {"name": "AUDD_API_TOKEN",         "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/AUDD_API_TOKEN"},
        {"name": "YOUTUBE_API_KEY",        "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/YOUTUBE_API_KEY"},
        {"name": "DATABASE_URL",           "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT:parameter/copyright/DATABASE_URL"}
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/copyright-detector",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },

      "mountPoints": [
        {
          "sourceVolume": "tmp-storage",
          "containerPath": "/app/temp",
          "readOnly": false
        }
      ],

      "ulimits": [
        {"name": "nofile", "softLimit": 65536, "hardLimit": 65536}
      ]
    }
  ],

  "volumes": [
    {
      "name": "tmp-storage",
      "host": {}
    }
  ]
}
